# ── 울산항만공사 Open API 인증키 ─────────────────────────────
# 공공데이터포털 마이페이지 > '일반 인증키(Decoding)' 값
UPA_SERVICE_KEY=여기에_발급키_입력

# ── PostgreSQL(RDS) 접속정보 (둘 중 한 방식) ─────────────────
# 방식1: 한 줄 URL
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
# 방식2: 개별 변수
PGHOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
PGPORT=5432
PGUSER=postgres
PGPASSWORD=여기에_DB_비밀번호
PGDATABASE=smartport
