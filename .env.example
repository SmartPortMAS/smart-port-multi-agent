# ── 울산항만공사 Open API ───────────────────────────────────────────────────
UPA_SERVICE_KEY=여기에_발급키_입력

# ── 공공데이터포탈 API 키 (디코딩된 값) ────────────────────────────────────
KOSHA_MSDS_API_KEY=여기에_디코딩된_API_키_입력
KHOA_API_KEY=여기에_KHOA_API_키_입력

# ── 기상청 APIHUB ───────────────────────────────────────────────────────────
KMA_BUOY_AUTH_KEY=여기에_기상청_APIHUB_인증키_입력
KMA_API_KEY=

# ── 해양수산부 항만기상정보시스템 ───────────────────────────────────────────
MMAF_API_KEY=여기에_항만기상_API_키_입력

# ── PostgreSQL (마스터 스테이징 DB) ────────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_DBNAME=smartport
PG_USER=postgres
PG_PASSWORD=여기에_PG_비밀번호_입력

# ── Neo4j (지식 그래프 마스터 DB) ──────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=여기에_NEO4J_비밀번호_입력
NEO4J_DATABASE=neo4j
